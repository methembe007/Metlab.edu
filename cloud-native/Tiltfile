# Frontend
docker_build(
    'metlab/frontend',
    './frontend',
    dockerfile='../infrastructure/docker/frontend.Dockerfile',
    live_update=[
        sync('./frontend/app', '/app/app'),
        run('cd /app && npm run build', trigger=['./frontend/app']),
    ]
)
k8s_yaml('infrastructure/k8s/frontend.yaml')
k8s_resource('frontend', port_forwards='3000:3000')

# Watch for proto file changes
watch_file('./proto')

# Local resource for proto generation
local_resource(
    'proto-gen',
    'make proto-gen',
    deps=['proto'],
    labels=['proto'],
)
