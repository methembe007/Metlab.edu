# Tiltfile for Metlab.edu Cloud-Native Development

# Load Kubernetes YAML
k8s_yaml('infrastructure/k8s/namespace.yaml')
k8s_yaml('infrastructure/k8s/postgres.yaml')
k8s_yaml('infrastructure/k8s/redis.yaml')

# API Gateway
docker_build(
    'metlab/api-gateway',
    '.',
    dockerfile='infrastructure/docker/api-gateway.Dockerfile',
    live_update=[
        sync('./services/api-gateway', '/app/services/api-gateway'),
        run('cd /app/services/api-gateway && go build -o /app/bin/api-gateway ./cmd/server', trigger=['./services/api-gateway']),
    ]
)
k8s_yaml('infrastructure/k8s/api-gateway.yaml')
k8s_resource('api-gateway', port_forwards='8080:8080')

# Auth Service
docker_build(
    'metlab/auth',
    '.',
    dockerfile='infrastructure/docker/auth.Dockerfile',
    live_update=[
        sync('./services/auth', '/app/services/auth'),
        run('cd /app/services/auth && go build -o /app/bin/auth ./cmd/server', trigger=['./services/auth']),
    ]
)
k8s_yaml('infrastructure/k8s/auth.yaml')
k8s_resource('auth', port_forwards='50051:50051')

