# Production Environment Variables Template
# Copy this file to .env.production and fill in the actual values
# DO NOT commit the actual .env.production file to version control

# Django Configuration
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this-in-production
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_SETTINGS_MODULE=metlab_edu.settings_production

# Database Configuration (PostgreSQL)
DB_NAME=metlab_edu_prod
DB_USER=metlab_user
DB_PASSWORD=metlab12345
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=ndlovumethembe06@gmail.com                    #your-email@yourdomain.com
EMAIL_HOST_PASSWORD=cbnpwgirljmkmqvy                                     #your-email-password
DEFAULT_FROM_EMAIL=ndlovumethembe06@gmail                 #noreply@yourdomain.com

# AI Services
OPENAI_API_KEY=your-openai-api-key

# WebRTC TURN Server Configuration
# For production, configure your own TURN server (e.g., Coturn)
# You can use services like Twilio, Agora, or self-hosted Coturn
TURN_SERVER_URL=turn:turn.yourdomain.com:3478
TURN_USERNAME=your-turn-username
TURN_PASSWORD=your-turn-password

# Optional: Secondary TURN server for redundancy
# TURN_SERVER_URL_2=turn:turn2.yourdomain.com:3478
# TURN_USERNAME_2=your-turn-username-2
# TURN_PASSWORD_2=your-turn-password-2

# Video Chat Settings
VIDEO_CHAT_MAX_PARTICIPANTS=30
VIDEO_CHAT_SESSION_TIMEOUT=3600  # 1 hour in seconds
VIDEO_CHAT_RECORDING_ENABLED=True
VIDEO_CHAT_SCREEN_SHARE_ENABLED=True

# File Upload Settings
MAX_FILE_SIZE=26214400  # 25MB in bytes
VIRUS_SCAN_ENABLED=True
MEDIA_ROOT=/var/www/metlab_edu/media

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# Data Privacy
DATA_RETENTION_DAYS=730  # 2 years

# CORS Settings (if needed)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Monitoring and Logging
SENTRY_DSN=your-sentry-dsn-if-using-sentry

# SSL/TLS Certificate paths (if using custom certificates)
SSL_CERT_PATH=/path/to/ssl/certificate.crt
SSL_KEY_PATH=/path/to/ssl/private.key

# Backup Configuration
BACKUP_STORAGE_PATH=/var/backups/metlab_edu
BACKUP_RETENTION_DAYS=30

# Performance Monitoring
PERFORMANCE_MONITORING_ENABLED=True
HEALTH_CHECK_ENABLED=True